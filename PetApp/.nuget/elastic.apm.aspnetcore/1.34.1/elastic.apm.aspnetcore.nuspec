        <dependency id="Elastic.Apm" version="1.34.1" exclude="Build,Analyzers" />
        <dependency id="Elastic.Apm.Extensions.Hosting" version="1.34.1" exclude="Build,Analyzers" />
        <dependency id="Microsoft.AspNetCore.Hosting.Abstractions" version="2.1.1" exclude="Build,Analyzers" />
