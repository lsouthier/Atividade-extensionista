        <member name="M:HealthChecks.UI.Configuration.Settings.SetApiMaxActiveRequests(System.Int32)">
            <summary>
            Sets limit on maximum active (concurrent) HTTP requests to <see cref="P:HealthChecks.UI.Configuration.Options.ApiPath"/> URL.
            If this limit is exceeded, requests to <see cref="P:HealthChecks.UI.Configuration.Options.ApiPath"/> return <see cref="F:Microsoft.AspNetCore.Http.StatusCodes.Status429TooManyRequests"/>.
            Initially, this value is set to 3.
            </summary>
            <param name="apiMaxActiveRequests">Concurrency limit.</param>
            <returns>Reference to the same <see cref="T:HealthChecks.UI.Configuration.Settings"/>.</returns>
        </member>
