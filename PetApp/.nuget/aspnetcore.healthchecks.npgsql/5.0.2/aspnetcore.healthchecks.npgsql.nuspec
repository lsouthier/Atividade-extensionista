<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>AspNetCore.HealthChecks.NpgSql</id>
    <version>5.0.2</version>
    <authors>Xabaril Contributors</authors>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">Apache-2.0</license>
    <licenseUrl>https://licenses.nuget.org/Apache-2.0</licenseUrl>
    <projectUrl>http://github.com/xabaril/AspNetCore.Diagnostics.HealthChecks</projectUrl>
    <description>HealthChecks.NpgSql is a health check for Postgress Sql.</description>
    <tags>HealthCheck Beat Health Postgress</tags>
    <repository type="git" url="https://github.com/xabaril/AspNetCore.Diagnostics.HealthChecks" commit="089db1c3dabb2c60fa534ee720a36648a65dce25" />
    <dependencies>
      <group targetFramework="net5.0">
        <dependency id="Microsoft.Extensions.Diagnostics.HealthChecks" version="5.0.1" exclude="Build,Analyzers" />
        <dependency id="Npgsql" version="5.0.3" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Microsoft.Extensions.Diagnostics.HealthChecks" version="5.0.1" exclude="Build,Analyzers" />
        <dependency id="Npgsql" version="5.0.3" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>