<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Dommel</id>
    <version>3.5.1</version>
    <authors>Henk Mollema</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>README.md</readme>
    <projectUrl>https://github.com/henkmollema/Dommel</projectUrl>
    <description>Simple CRUD operations for Dapper.</description>
    <copyright>Copyright © Henk Mollema 2014</copyright>
    <tags>dommel crud dapper database orm</tags>
    <repository type="git" url="https://github.com/henkmollema/Dommel" branch="refs/heads/master" commit="08bedf2cb65814dda9db3bfcabe8630d267cb1bc" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="Dapper" version="2.1.66" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net9.0">
        <dependency id="Dapper" version="2.1.66" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net10.0">
        <dependency id="Dapper" version="2.1.66" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Dapper" version="2.1.66" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Bcl.HashCode" version="6.0.0" exclude="Build,Analyzers" />
        <dependency id="System.ComponentModel.Annotations" version="5.0.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>