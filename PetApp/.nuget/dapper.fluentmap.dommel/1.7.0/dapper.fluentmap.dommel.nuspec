<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Dapper.FluentMap.Dommel</id>
    <version>1.7.0</version>
    <authors>Henk Mollema</authors>
    <owners>Henk Mollema</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <licenseUrl>https://github.com/henkmollema/Dapper-FluentMap/blob/master/LICENSE</licenseUrl>
    <projectUrl>https://github.com/henkmollema/Dapper-FluentMap</projectUrl>
    <description>Dapper.FluentMap extension for Dommel support.</description>
    <copyright>Copyright © Henk Mollema 2017</copyright>
    <tags>dapper fluentmap dommel</tags>
    <dependencies>
      <group targetFramework=".NETFramework4.5.1">
        <dependency id="Dapper.FluentMap" version="1.8.0" exclude="Build,Analyzers" />
        <dependency id="Dapper" version="1.60.1" exclude="Build,Analyzers" />
        <dependency id="Dommel" version="1.11.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard1.3">
        <dependency id="Dapper.FluentMap" version="1.8.0" exclude="Build,Analyzers" />
        <dependency id="Dapper" version="1.60.1" exclude="Build,Analyzers" />
        <dependency id="Dommel" version="1.11.0" exclude="Build,Analyzers" />
        <dependency id="NETStandard.Library" version="1.6.1" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Dapper.FluentMap" version="1.8.0" exclude="Build,Analyzers" />
        <dependency id="Dapper" version="1.60.1" exclude="Build,Analyzers" />
        <dependency id="Dommel" version="1.11.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>