    <repository type="git" url="https://github.com/xabaril/AspNetCore.Diagnostics.HealthChecks" commit="365097bf535212384015d0b4d2405e55ad33f653" />
    <dependencies>
      <group targetFramework="net5.0">
        <dependency id="Microsoft.Extensions.Diagnostics.HealthChecks" version="5.0.1" exclude="Build,Analyzers" />
        <dependency id="NEST" version="7.9.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Microsoft.Extensions.Diagnostics.HealthChecks" version="5.0.1" exclude="Build,Analyzers" />
